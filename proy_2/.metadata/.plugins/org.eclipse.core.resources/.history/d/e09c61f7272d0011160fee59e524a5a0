package com_proy_2_services;

import java.util.List;

import com_proy_2_dao.IVehiculoDAO;
import com_proy_2_dao.VehiculoDAO;
import com_proy_2_entity.Vehiculo;

public class VehiculoService {
	
	private IVehiculoDAO dao;
	
	public VehiculoService() {
		this.dao = new VehiculoDAO();
	}
	
	public List<Vehiculo> obtenerTodos(){
		return dao.getAll();
	}
	
	public Vehiculo obtenerPorId(int id) {
		
		if(id <= 0) {
			throw new RuntimeException("El id no puede ser menor o igual a 0");
		}
		
		Vehiculo v = dao.getById(id);
		
		if(v == null) {
			throw new RuntimeException("No se encontró el vehiculo con la id " + id);
		}
		
		return v;
		
	}

	public boolean agregarVehiculo(Vehiculo v) {
		
		if (v == null) {
			throw new RuntimeException("El vehiculo a agregar no existe");
		}
		this.dao.add(v);
		return true;
		
	}
	
	public boolean actualizarVehiculo(Vehiculo v) {
		
