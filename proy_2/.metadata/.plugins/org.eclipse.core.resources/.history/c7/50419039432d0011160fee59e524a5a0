package com_proy_2_program;

import com_proy_2_database.JPAUtil;
import com_proy_2_entity.Auto;
import com_proy_2_entity.Moto;
import com_proy_2_entity.Vehiculo;
import com_proy_2_services.VehiculoService;

public class Program {

	public static void main(String[] args) {
		VehiculoService service = new VehiculoService();

	    // Agregar un Auto
	    Auto a = new Auto("Toyota", 15000.00, 2022, 4);
	    a.setId(1);
	    service.agregarVehiculo(a);

	    // Agregar una Moto
	    Moto m = new Moto("Honda", 8000.00, 2023, 600);
	    service.agregarVehiculo(m);

	    // Listar todos
	    for(Vehiculo v : service.obtenerTodos()) {
	        System.out.println(v.toString());
	    }

	    JPAUtil.close();
	}

}
